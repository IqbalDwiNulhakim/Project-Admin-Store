<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — AdminStore</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
  <div class="layout">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-brand">
        <i class="fas fa-store"></i>
        <span>AdminStore</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/" class="nav-item <%= active === 'dashboard' ? 'active' : '' %>">
          <i class="fas fa-chart-pie"></i> Dashboard
        </a>
        <a href="/products" class="nav-item <%= active === 'products' ? 'active' : '' %>">
          <i class="fas fa-box"></i> Produk
        </a>
        <a href="/stock" class="nav-item <%= active === 'stock' ? 'active' : '' %>">
          <i class="fas fa-warehouse"></i> Stok
        </a>
        <a href="/purchases" class="nav-item <%= active === 'purchases' ? 'active' : '' %>">
          <i class="fas fa-shopping-cart"></i> Pembelian
        </a>
      </nav>
      <div class="sidebar-footer">
        <i class="fas fa-circle-user"></i> Admin Toko
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main">
      <div class="topbar">
        <h1 class="page-title"><%= title %></h1>
        <div class="topbar-right">
          <span class="date-badge"><i class="fas fa-calendar"></i> <span id="date-now"></span></span>
        </div>
      </div>
      <div class="content">
