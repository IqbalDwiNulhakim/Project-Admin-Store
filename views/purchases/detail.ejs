<%- include('../partials/header') %>

<div class="card card-form">
  <div class="card-header">
    <h3><i class="fas fa-file-invoice"></i> Detail Pembelian</h3>
    <a href="/purchases" class="btn btn-sm btn-outline"><i class="fas fa-arrow-left"></i> Kembali</a>
  </div>
  <div class="card-body">
    <div class="invoice-box">
      <div class="invoice-header">
        <div>
          <h2 class="invoice-title">INVOICE</h2>
          <p class="invoice-no"><%= purchase.invoice_no %></p>
        </div>
        <span class="badge badge-lg <%= purchase.status === 'active' ? 'badge-green' : 'badge-red' %>">
          <%= purchase.status === 'active' ? '✓ AKTIF' : '✗ DIBATALKAN' %>
        </span>
      </div>
      <div class="invoice-meta">
        <div>
          <p class="meta-label">Pelanggan</p>
          <p class="meta-value"><%= purchase.customer_name %></p>
        </div>
        <div>
          <p class="meta-label">Tanggal Pembelian</p>
          <p class="meta-value"><%= purchase.created_at %></p>
        </div>
        <% if (purchase.status === 'cancelled') { %>
        <div>
          <p class="meta-label">Tanggal Pembatalan</p>
          <p class="meta-value text-danger"><%= purchase.cancelled_at %></p>
        </div>
        <% } %>
      </div>
      <table class="invoice-table">
        <thead>
          <tr>
            <th>Produk</th>
            <th>Kategori</th>
            <th>Harga Satuan</th>
            <th>Qty</th>
            <th>Subtotal</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong><%= purchase.product_name %></strong></td>
            <td><%= purchase.category %></td>
            <td>Rp <%= Number(purchase.unit_price).toLocaleString('id-ID') %></td>
            <td><%= purchase.quantity %></td>
            <td><strong>Rp <%= Number(purchase.total_price).toLocaleString('id-ID') %></strong></td>
          </tr>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="4" class="text-right"><strong>TOTAL</strong></td>
            <td><strong class="text-xl">Rp <%= Number(purchase.total_price).toLocaleString('id-ID') %></strong></td>
          </tr>
        </tfoot>
      </table>
      <% if (purchase.notes) { %>
      <div class="invoice-notes">
        <strong>Catatan:</strong> <%= purchase.notes %>
      </div>
      <% } %>
      <% if (purchase.status === 'cancelled') { %>
      <div class="invoice-cancel-reason">
        <strong><i class="fas fa-ban"></i> Alasan Pembatalan:</strong>
        <p><%= purchase.cancel_reason %></p>
      </div>
      <% } %>
    </div>

    <% if (purchase.status === 'active') { %>
    <div class="form-actions mt-3">
      <button class="btn btn-danger" onclick="openCancelModal(<%= purchase.id %>, '<%= purchase.invoice_no %>')">
        <i class="fas fa-ban"></i> Batalkan Pembelian
      </button>
    </div>
    <% } %>
  </div>
</div>

<!-- Modal Cancel -->
<div id="cancelModal" class="modal-overlay" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="fas fa-ban"></i> Batalkan Pembelian</h3>
      <button onclick="closeCancelModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <p class="text-muted mb-2">Invoice: <strong id="cancel-invoice-no"></strong></p>
      <p class="alert alert-warning"><i class="fas fa-triangle-exclamation"></i> Stok produk akan dikembalikan otomatis.</p>
      <form id="cancelForm" method="POST">
        <div class="form-group">
          <label>Alasan Pembatalan</label>
          <textarea name="cancel_reason" class="form-control" rows="3" placeholder="Tuliskan alasan pembatalan..." required></textarea>
        </div>
        <div class="form-actions">
          <button type="button" onclick="closeCancelModal()" class="btn btn-outline">Tutup</button>
          <button type="submit" class="btn btn-danger"><i class="fas fa-ban"></i> Konfirmasi Batalkan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function openCancelModal(id, invoice) {
    document.getElementById('cancel-invoice-no').textContent = invoice;
    document.getElementById('cancelForm').action = `/purchases/cancel/${id}`;
    document.getElementById('cancelModal').style.display = 'flex';
  }
  function closeCancelModal() {
    document.getElementById('cancelModal').style.display = 'none';
  }
</script>

<%- include('../partials/footer') %>
