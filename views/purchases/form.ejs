<%- include('../partials/header') %>

<div class="card card-form">
  <div class="card-header">
    <h3><i class="fas fa-plus-circle"></i> Input Pembelian</h3>
    <a href="/purchases" class="btn btn-sm btn-outline"><i class="fas fa-arrow-left"></i> Kembali</a>
  </div>
  <div class="card-body">
    <% if (error) { %>
    <div class="alert alert-danger"><i class="fas fa-circle-xmark"></i> <%= error %></div>
    <% } %>
    <form method="POST" action="/purchases/add" id="purchaseForm">
      <div class="form-grid">
        <div class="form-group form-full">
          <label>Pilih Produk <span class="required">*</span></label>
          <select name="product_id" class="form-control" required id="product-select" onchange="updatePrice()">
            <option value="">-- Pilih Produk --</option>
            <% products.forEach(p => { %>
            <option value="<%= p.id %>" data-price="<%= p.price %>" data-stock="<%= p.stock %>">
              <%= p.name %> — Rp <%= Number(p.price).toLocaleString('id-ID') %> (Stok: <%= p.stock %>)
            </option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Stok Tersedia</label>
          <input type="text" id="available-stock" class="form-control" disabled value="-">
        </div>
        <div class="form-group">
          <label>Jumlah Beli <span class="required">*</span></label>
          <input type="number" name="quantity" id="qty-input" class="form-control" min="1" required placeholder="Jumlah" oninput="calcTotal()">
        </div>
        <div class="form-group">
          <label>Harga Satuan</label>
          <input type="text" id="unit-price" class="form-control" disabled value="-">
        </div>
        <div class="form-group">
          <label>Total Harga</label>
          <input type="text" id="total-display" class="form-control form-highlight" disabled value="-">
        </div>
        <div class="form-group form-full">
          <label>Nama Pelanggan <span class="required">*</span></label>
          <input type="text" name="customer_name" class="form-control" required placeholder="Nama lengkap pelanggan">
        </div>
        <div class="form-group form-full">
          <label>Catatan</label>
          <textarea name="notes" class="form-control" rows="2" placeholder="Catatan tambahan (opsional)..."></textarea>
        </div>
      </div>
      <div class="form-actions">
        <a href="/purchases" class="btn btn-outline">Batal</a>
        <button type="submit" class="btn btn-primary">
          <i class="fas fa-save"></i> Simpan Pembelian
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  function updatePrice() {
    const sel = document.getElementById('product-select');
    const opt = sel.options[sel.selectedIndex];
    if (!opt || !opt.value) {
      document.getElementById('available-stock').value = '-';
      document.getElementById('unit-price').value = '-';
      document.getElementById('total-display').value = '-';
      return;
    }
    const price = parseInt(opt.dataset.price);
    const stock = parseInt(opt.dataset.stock);
    document.getElementById('available-stock').value = stock + ' unit';
    document.getElementById('unit-price').value = 'Rp ' + price.toLocaleString('id-ID');
    document.getElementById('qty-input').max = stock;
    calcTotal();
  }

  function calcTotal() {
    const sel = document.getElementById('product-select');
    const opt = sel.options[sel.selectedIndex];
    const qty = parseInt(document.getElementById('qty-input').value);
    if (!opt || !opt.value || isNaN(qty)) {
      document.getElementById('total-display').value = '-';
      return;
    }
    const price = parseInt(opt.dataset.price);
    const total = price * qty;
    document.getElementById('total-display').value = 'Rp ' + total.toLocaleString('id-ID');
  }
</script>

<%- include('../partials/footer') %>
